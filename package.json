{
  "name": "vectis",
  "version": "1.0.7",
  "description": "SVG manipulation library written in TypeScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ormidales/vectis.git"
  },
  "keywords": ["svg", "canvas", "typescript"],
  "author": "Hugo Doueil <46538211+ormidales@users.noreply.github.com>",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "bugs": {
    "url": "https://github.com/ormidales/vectis/issues"
  },
  "homepage": "https://github.com/ormidales/vectis#readme"
}
